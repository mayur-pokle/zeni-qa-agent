    "styled-jsx": "^5.1.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.2"
