{
  "name": "flowtest-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build",
    "start": "next start",
    "worker": "node monitoring/scheduler.js",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node --import tsx prisma/seed.ts",
    "playwright:test": "playwright test",
    "playwright:test:critical": "playwright test --grep @critical",
    "playwright:update-snapshots": "playwright test --update-snapshots",
    "playwright:install": "playwright install",
    "monitor:poll": "tsx scripts/poll-monitoring.ts",
    "monitor:run": "node monitoring/runner.js",
    "monitor:schedule": "node monitoring/scheduler.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@tailwindcss/postcss": "^4.1.3",
    "clsx": "^2.1.1",
    "csv-stringify": "^6.5.2",
    "date-fns": "^4.1.0",
    "lighthouse": "^12.3.0",
    "lucide-react": "^0.511.0",
    "next": "15.5.14",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "playwright": "^1.52.0",
    "playwright-lighthouse": "^3.2.2",
    "prisma": "^6.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
